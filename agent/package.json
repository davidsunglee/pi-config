{
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint \"extensions/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "build": "npm run lint && npm run typecheck",
    "test": "find extensions -name '*.test.ts' -print0 | xargs -0 node --experimental-strip-types --experimental-test-coverage --test",
    "check": "npm run build && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mariozechner/pi-ai": "0.72.1",
    "@mariozechner/pi-coding-agent": "0.72.1",
    "@mariozechner/pi-tui": "0.72.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "typebox": "^1.1.37",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
